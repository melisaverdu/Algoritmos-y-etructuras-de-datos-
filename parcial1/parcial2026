template <typename TData>
void printQueueHelper(Queue<TData>& q) {
    std::size_t n = q.size();
    for (std::size_t i = 0; i < n; ++i) {
        TData val = q.front();
        std::cout << val << (i + 1 < n ? " " : "");
        q.dequeue();
        q.enqueue(val);
    }
    std::cout << "\n";
}

template <typename TData>
void printStackHelper(Stack<TData> s) { // Recibe por copia de forma segura para imprimir
    Stack<TData> temp;
    while (!s.isEmpty()) {
        temp.push(s.top());
        s.pop();
    }
    while (!temp.isEmpty()) {
        std::cout << temp.top() << (temp.size() > 1 ? " " : "");
        temp.pop();
    }
    std::cout << "\n";
}

