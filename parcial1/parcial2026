/*
  CONTEXTO:
  El pipeline de procesamiento de comandos de drones apila instrucciones en orden 
  de llegada. Ante una señal de reversión, el sistema debe invertir el orden del 
  stack de comandos pendientes antes de ejecutarlos.

  TAREA:
  Implementar el método Stack<TData> invertir() const dentro de la clase Stack<TData>.
  El método debe retornar un NUEVO stack con los elementos en orden inverso al original.
  El stack original NO debe modificarse.

  RESTRICCIONES:
  - Solo usar las operaciones públicas del ADT: push, pop, top, isEmpty, size.
  - Se permite usar un segundo Stack<TData> auxiliar.
  - No usar arrays, vectores ni estructuras de la STL.
*/

template <typename TData>
class Stack {
private:
    struct Node {
        TData data;
        Node* next;
        explicit Node(const TData& d) : data(d), next(nullptr) {}
    };
    Node* m_top;
    std::size_t m_size;

public:
    Stack() : m_top(nullptr), m_size(0) {}
    ~Stack() { while (!isEmpty()) pop(); }

    void push(const TData& value) {
        Node* n = new Node(value);
        n->next = m_top;
        m_top = n;
        ++m_size;
    }

    void pop() {
        if (isEmpty()) throw std::underflow_error("Stack: pop stack vacio");
        Node* tmp = m_top;
        m_top = m_top->next;
        delete tmp;
        --m_size;
    }

    const TData& top() const {
        if (isEmpty()) throw std::underflow_error("Stack: top stack vacio");
        return m_top->data;
    }

    bool isEmpty() const { return m_top == nullptr; }
    std::size_t size() const { return m_size; }

    // ------------------------------------------------------------------------
    // IMPLEMENTAR PUNTO 2
    // ------------------------------------------------------------------------
    Stack<TData> invertir() const {
        // --- TU TAREA ---
        // Tu código acá...
        // Nota: Recordá que este método es 'const', por lo tanto NO podés 
        // modificar el stack que lo llama (this). Deberás desapilar una copia
        // o utilizar auxiliares de manera segura sin destruir la pila actual.

        if(size()<=1){
            return this;
        }
        
        Stack<TData> copia = *this;
        Stack<TData> resultado;
        std::size_t tam = size(); //tamaño de la pila original 

        for(std::size_t i = 0; i<tam; i++){
            resultado.push(copia.top());
            copia.pop();
        }

        return resultado;

    }
};


