// PUNTO 3: LISTA DOBLEMENTE ENLAZADA - ELIMINACIÓN DE DUPLICADOS (Vale 25 puntos)
// ============================================================================
// ============================================================================
/*
  CONTEXTO:
  Los logs de actividad neuronal se almacenan en una lista doblemente enlazada. 
  Los registros duplicados consecutivos representan redundancia y deben ser 
  eliminados para reducir el costo de transmisión.

  TAREA:
  Implementar el método void eliminarDuplicados() dentro de la clase DLL<TData>.
  El método debe eliminar todos los nodos cuyo valor sea igual al del nodo 
  inmediatamente anterior. La lista debe modificarse in-place y la 
  memoria de los nodos eliminados debe liberarse correctamente.

  RESTRICCIONES:
  - NO usar estructuras auxiliares (arrays, vectores, stacks, queues).
  - Mantener correctos los punteros prev y next de todos los nodos sobrevivientes, 
    incluyendo m_head y m_tail.
  - Actualizar m_size correctamente.
*/

template <typename TData>
class DLL {
private:
    struct Node {
        TData data;
        Node* next;
        Node* prev;
        explicit Node(const TData& d) : data(d), next(nullptr), prev(nullptr) {}
    };
    Node* m_head;
    Node* m_tail;
    std::size_t m_size;

public:
    DLL() : m_head(nullptr), m_tail(nullptr), m_size(0) {}
    ~DLL() {
        while (m_head) {
            Node* tmp = m_head;
            m_head = m_head->next;
            delete tmp;
        }
    }

    void pushBack(const TData& value) {
        Node* n = new Node(value);
        if (!m_head) {
            m_head = n;
            m_tail = n;
        } else {
            m_tail->next = n;
            n->prev = m_tail;
            m_tail = n;
        }
        ++m_size;
    }

    std::size_t size() const { return m_size; }

    void print() const {
        Node* curr = m_head;
        while (curr) {
            std::cout << curr->data;
            if (curr->next) std::cout << " ";
            curr = curr->next;
        }
        std::cout << "\n";
    }

    // ------------------------------------------------------------------------
    // IMPLEMENTAR PUNTO 3
    // ------------------------------------------------------------------------
    void eliminarDuplicados() {
        // --- TU TAREA ---
        // Tu código acá...
        // Recordá actualizar m_size y liberar la memoria con 'delete'
        // cuando desconectes un nodo duplicado de la lista.

        if(size()<=1){
            return;
        }
        
        Node* aux = m_head;


        while(aux != nullptr && aux->next != nullptr){

            if(aux->next == nullptr && aux->data == aux->prev->data){
                Node*temp = aux;
                aux->prev->next = nullptr;
                m_tail = m_head;
                delete temp;

            }else if(aux->data == aux->next->data && aux->next != m_tail){
                Node* temp = aux->next;
                aux->next = aux->next->next;
                aux->next->prev = aux;
                delete temp;
            }

            aux = aux->next;

        }

        
    }
};


