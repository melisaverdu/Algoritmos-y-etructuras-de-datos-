/*
EJERCICIO 1 — BST: Búsqueda por código
Enunciado

CyberCórdoba Trenes — Registro operativo de convoyes prioritarios

Durante la madrugada, el Centro de Control Ferroviario recibe solicitudes de despacho desde distintos nodos de
 la ciudad. Cada solicitud incluye el código operativo de un tren.

Para evitar recorrer todo el registro linealmente, los trenes se almacenan en un Árbol Binario de Búsqueda (BST)
ordenado por Tren.codigo.

Implementar:

ResultadoBusqueda RegistroTrenes::buscarPorCodigo(int codigoBuscado);

Debe devolver:

ResultadoBusqueda(true, tren)

si existe un tren con ese código.

o

ResultadoBusqueda(false, Tren())

si no existe.

Restricciones
-Usar la propiedad del BST.
-No recorrer ambos subárboles.
-No usar STL.
-No modificar el árbol.

*/

#include <iostream>
#include <string>

struct Tren {
    int codigo;
    std::string linea;
    int prioridadOperativa;

    Tren(int codigoTren = -1,
         std::string lineaTren = "",
         int prioridad = 0)
        : codigo(codigoTren),
          linea(lineaTren),
          prioridadOperativa(prioridad) {}
};

struct ResultadoBusqueda {
    bool encontrado;
    Tren tren;

    ResultadoBusqueda(bool fueEncontrado = false,
                      Tren trenEncontrado = Tren())
        : encontrado(fueEncontrado),
          tren(trenEncontrado) {}
};

class NodoTren {
public:
    Tren dato;
    NodoTren* izquierdo;
    NodoTren* derecho;

    explicit NodoTren(Tren tren)
        : dato(tren),
          izquierdo(nullptr),
          derecho(nullptr) {}
};

class RegistroTrenes {
private:
    NodoTren* raiz;

public:
    RegistroTrenes() : raiz(nullptr) {}

    ResultadoBusqueda buscarPorCodigo(int codigoBuscado);
};


ResultadoBusqueda RegistroTrenes::buscarPorCodigo(int codigoBuscado) {
    // IMPLEMENTAR RESOLUCIÓN
    NodoTren* actual = raiz;

    while(actual != nullptr){

        if(actual->dato.codigo == codigoBuscado){
            return ResultadoBusqueda(true, actual->dato);
        }
        else if(actual->dato.codigo > codigoBuscado){
            actual = actual->izquierdo;
        }
    }
}

