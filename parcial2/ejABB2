#include <iostream>
using namespace std;

class Nodo {
public:
    int dato;
    Nodo* izq;
    Nodo* der;

    explicit Nodo(const int& x): dato(x), izq(nullptr), der(nullptr) {}
};

class ABB {

private:

    Nodo* raiz = nullptr;

    const Nodo* minNode(const Nodo* p) const {

        if (!p)
            return nullptr;

        if (!p->izq)
            return p;

        return minNode(p->izq);
    }

    Nodo* borrarRec(Nodo* p, const int& x);

public:

    ABB() = default;

    void borrar(const int& x);
};

// ======================================
// IMPLEMENTAR ACA
// ======================================

Nodo* ABB::borrarRec(Nodo* p, const int& x) {
    if(p==nullptr){
        return nullptr;
    }
    if(x < p->dato){
        p->izq = borrarRec(p->izq, x);
    } else if(x > p->dato){
        p->der = borrarRec(p->der, x);
    } else {
        // Nodo con un solo hijo o sin hijos
        if(p->izq == nullptr){
            Nodo* temp = p->der;
            delete p;
            return temp;
        } else if(p->der == nullptr){
            Nodo* temp = p->izq;
            delete p;
            return temp;
        }

        // Nodo con dos hijos: Obtener el sucesor inorden
        const Nodo* temp = minNode(p->der);

        // Copiar el valor del sucesor al nodo actual
        p->dato = temp->dato;

        // Eliminar el sucesor inorden
        p->der = borrarRec(p->der, temp->dato);
    }
}

void ABB::borrar(const int& x) {
    raiz = borrarRec(raiz, x);
}

