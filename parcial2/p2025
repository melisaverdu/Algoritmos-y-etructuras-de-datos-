// PREGUNTA 1: ARBOL BINARIO - MAX-HEAP (Puntúa 40 sobre 40)
// =============================================================================
/*
Implementar el método bool ArbolBinario::esMaxHeap() de la clase ArbolBinario. 
Este método debe determinar si el árbol binario almacenado es un Max-Heap.

Max-Heap (Propiedad del Montículo): Para todo nodo, su valor es mayor o igual 
que el valor de sus hijos (si existen).
Un árbol con raíz nullptr se considera un Max-Heap.
*/

struct NodoArbol {
    int valor;
    NodoArbol* izquierda;
    NodoArbol* derecha;
    NodoArbol(int v) : valor(v), izquierda(nullptr), derecha(nullptr) {}
};

class ArbolBinario {
private:
    NodoArbol* raiz;

    void destruir(NodoArbol* nodo) {
        if (nodo != nullptr) {
            destruir(nodo->izquierda);
            destruir(nodo->derecha);
            delete nodo;
        }
    }

    // -------------------------------------------------------------------------
    // A IMPLEMENTAR: Método recursivo auxiliar
    // -------------------------------------------------------------------------
    bool esMaxHeapRec(NodoArbol* nodo) {
        // TU CÓDIGO AQUÍ:
        if(nodo == nullptr){
            return true;
        }

        bool izqok = true;
        bool derok = true;

        if(nodo->izquierda != nullptr){
            if(nodo->valor >= nodo->izquierda->valor){ //tengo que verificar el izquierdo
                izqok = esMaxHeapRec(nodo->izquierda);
            }else{
                izqok = false;
            }
        }

        if(nodo->derecha != nullptr){
            if(nodo->valor >= nodo->derecha->valor){ //tengo que verificar el izquierdo
                derok = esMaxHeapRec(nodo->derecha);
            }else{
                derok = false;
            }
        }
        return (izqok && derok);
    }

public:
    ArbolBinario() : raiz(nullptr) {}
    
    ~ArbolBinario() {
        destruir(raiz);
    }

    void setRaiz(NodoArbol* nuevaRaiz) {
        if (raiz != nullptr) {
            destruir(raiz);
        }
        raiz = nuevaRaiz;
    }

    // -------------------------------------------------------------------------
    // A IMPLEMENTAR: Método público
    // -------------------------------------------------------------------------
    bool esMaxHeap() {
        // TU CÓDIGO AQUÍ:
        return esMaxHeapRec(raiz);
    }
};


// =============================================================================
// PREGUNTA 2: GRAFOS - BIPARTITO CON DFS (Puntúa 30 sobre 30)
// =============================================================================
/*
Implementar el método bool Grafo::esBipartito() de la clase Grafo. 
Este método debe determinar si el grafo no dirigido almacenado es bipartito.

Grafo Bipartito: Un grafo es bipartito si es posible "colorear" cada uno de sus 
vértices con uno de dos colores (por ejemplo, Color 0 y Color 1) de tal manera 
que ninguna arista conecte dos vértices del mismo color.

Deberás utilizar un método auxiliar recursivo basado en Recorrido en Profundidad (DFS):
bool esBipartitoRec(int u, int colorActual, int colores[]);
 - u: El vértice que se está visitando actualmente.
 - colores: Arreglo para almacenar el color de cada vértice.
            (-1 para "no coloreado", 0 para Color 0, 1 para Color 1).
 - colorActual: El color (0 o 1) que se debe asignar al vértice u.

Asigna el color actual a u, luego calcula el color esperado para los vecinos y 
se llama recursivamente para las adyacencias que aún no fueron coloreadas.
 - Devuelve false, si alguna llamada recursiva devuelve false.
 - Devuelve false, si la adyacencia ya estaba coloreada y tiene el mismo color que u.
 - Si no aplica ninguno de los casos anteriores para ninguna adyacencia devuelve true.

El método principal esBipartito() deberá inicializar el arreglo colores (todo a -1) 
y llamar a esBipartitoRec para cada vértice que no haya sido coloreado. 
Devuelve false si alguna llamada a esBipartitoRec devuelve false.
*/

class Grafo {
private:
    int V;
    std::list<int>* adj;

    // -------------------------------------------------------------------------
    // A IMPLEMENTAR: Auxiliar recursivo (DFS)
    // -------------------------------------------------------------------------
    bool esBipartitoRec(int u, int colorActual, int colores[]) {
    // 1. Asigno el color actual al nodo donde estoy parado
        colores[u] = colorActual; 

    // 2. Calculo el color que deberían tener mis vecinos
        int colorVecino = colorActual;
        if(colorVecino == 1){
            colorVecino = 0;
        } else {
            colorVecino = 1;
        }

    // 3. Recorremos los vecinos usando el for corto
        for(int vecinos : adj[u]){
            
            // CASO A: El vecino no está coloreado
            if(colores[vecinos] == -1){
                // Llamamos recursivamente y SI DA FALSE, cortamos y subimos el false
                if (esBipartitoRec(vecinos, colorVecino, colores) == false) {
                    return false;
                }
            }
            // CASO B: El vecino ya estaba coloreado. ¡Solo falla si tiene MI MISMO color!
            else if (colores[vecinos] == colorActual) {
                return false;
            }
    }

    // 4. Si revisó todos los vecinos y ninguno rompió las reglas: este camino está OK
    return true;
}
    

public:
    Grafo(int V) {
        this->V = V;
        this->adj = new std::list<int>[V];
    }

    ~Grafo() {
        delete[] adj;
    }

    void agregarArista(int u, int v) {
        if (u >= 0 && u < V && v >= 0 && v < V) {
            adj[u].push_back(v);
            adj[v].push_back(u);
        }
    }

    // -------------------------------------------------------------------------
    // A IMPLEMENTAR: Método principal
    // -------------------------------------------------------------------------
    bool esBipartito() {
        // TU CÓDIGO AQUÍ:
       //ESTA RESUELTA EN EL CUADERNO COPIALA
    };
};


