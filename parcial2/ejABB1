#include <iostream>
#include <cmath>
using namespace std;

struct Nodo {

    int dato;
    Nodo* izquierdo;
    Nodo* derecho;

    Nodo(int v)
        : dato(v), izquierdo(nullptr), derecho(nullptr) {}
};

class BST {

private:

    Nodo* raiz;

    // Retorna altura si está balanceado
    // o -1 si no lo está
    int BST::esBalanceadoRecursivo(Nodo* nodo) {

    // Caso base
    if(nodo == nullptr) {
        return 0;
    }

    // Calcular altura izquierda
    int alturaIzq = esBalanceadoRecursivo(nodo->izquierdo);

    // Si izquierda ya está desbalanceada
    if(alturaIzq == -1) {
        return -1;
    }

    // Calcular altura derecha
    int alturaDer = esBalanceadoRecursivo(nodo->derecho);

    // Si derecha ya está desbalanceada
    if(alturaDer == -1) {
        return -1;
    }

    // Verificar diferencia de alturas
    if(abs(alturaIzq - alturaDer) > 1) {
        return -1;
    }

    // Retornar altura actual
    return 1 + max(alturaIzq, alturaDer);
}

bool BST::esBalanceado() {

    return esBalanceadoRecursivo(raiz) != -1;
}


public:

    BST() : raiz(nullptr) {}

    BST(Nodo* valor): raiz(valor) {}

    bool esBalanceado(){
        return esBalanceadoRecursivo(raiz) != -1;
    }
};
