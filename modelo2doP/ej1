#include <iostream>
#include <string>

using namespace std;
/*
Enunciado:
CyberCórdoba Trenes — Ruta energética mínima

Durante la madrugada, algunos túneles consumen distinta cantidad de energía por interferencias electromagnéticas. 
Antes de enviar un tren de mantenimiento, el centro de control debe calcular el costo energético mínimo entre dos 
estaciones.

La red se modela como un grafo ponderado:

    Cada estación es un nodo.
    Cada túnel bidireccional tiene un costo energético positivo.
    El costo de una ruta es la suma de los costos de sus túneles.

Como todos los costos son positivos, la estrategia correcta es Dijkstra.

Implemente exactamente este método:

int MetroNocturno::costoMinimoEnergia(int origenId, int destinoId)

Debe devolver:

    -1 si algún id es inválido.
    -1 si no existe ruta.
    0 si origen y destino coinciden.
    El costo energético mínimo en cualquier otro caso.

*/
/*
Identifico cada cosa:
-nodos -> estaciones
-aristas -> túneles
-peso -> costo energético
*/
struct Tunel {
    bool existe;
    int costoEnergia;

    Tunel(bool existeTunel = false, int costo = 0) {
        existe = existeTunel;
        costoEnergia = costo;
    }
};

class MetroNocturno {
    private:
        static const int MAX_ESTACIONES = 20;
        static const int COSTO_INFINITO = 999999;

        string nombres[MAX_ESTACIONES];
        Tunel conexiones[MAX_ESTACIONES][MAX_ESTACIONES];
        int cantidadEstaciones;

    public:

    MetroNocturno() {
        cantidadEstaciones = 0;
        for (int i = 0; i < MAX_ESTACIONES; i++) {
            for (int j = 0; j < MAX_ESTACIONES; j++) {
                conexiones[i][j] = Tunel(false, 0);
            }
        }
    }    

    int agregarEstacion(string nombre) {
        if (cantidadEstaciones >= MAX_ESTACIONES) return -1;
        nombres[cantidadEstaciones] = nombre;
        cantidadEstaciones++;
        return cantidadEstaciones - 1;
    }

    void conectarBidireccional(int origenId, int destinoId, int costoEnergia) {
        if (origenId >= 0 && origenId < MAX_ESTACIONES && destinoId >= 0 && destinoId < MAX_ESTACIONES) {
            conexiones[origenId][destinoId] = Tunel(true, costoEnergia);
            conexiones[destinoId][origenId] = Tunel(true, costoEnergia);
        }
    }

    // =========================================================================
    // MÉTODO A IMPLEMENTAR
    // =========================================================================
    int costoMinimoEnergia(int origenId, int destinoId) {
        
        // 1. VALIDACIONES
        if(origenId < 0 || origenId >= cantidadEstaciones || destinoId < 0 || destinoId >= cantidadEstaciones){
            return -1;
        }
        if(origenId == destinoId){
            return 0;
        }

        // 2. ESTRUCTURAS QUE NECESITA DIJKSTRA
        int distancia[cantidadEstaciones];
        int visitados[cantidadEstaciones];
        
        // 3. INICIALIZACIÓN
        for(int i = 0; i < cantidadEstaciones; i++){
            distancia[i] = COSTO_INFINITO;
            visitados[i]= false;
        }
        distancia[origenId] = 0;

        // 4. BUCLE PRINCIPAL:Bucle de Dijkstra (Iterar buscando el nodo no visitado con menor distancia).
        for(int k = 0; k < cantidadEstaciones; k++){

            int actual = -1; // empiezo antes de 0
            int menor = COSTO_INFINITO; // empiezo con el mayor costo para comparar

            //BUSCAR EL NODO NO VISITADO CON MENOR DISTANCIA.
            for(int i = 0; i < cantidadEstaciones; i++){ // recorro cantidadEstaciones
                if(visitados[i] == false && distancia[i] < menor){ // si 0 no esta visitado y distancia[0] < menor(que es el maximo posible)
                    menor = distancia[i]; //ahora el menor es distancia[0] que encontre mas chica que el COSTO_INFINITO
                    actual = i; // actual es en el que estoy parado seguen el for, el que encontré con menor distancia, por eso entro aca
                }
            }

            //NO HAY AMS NODOS ALCANZABLES
            if(actual == -1){
                break;                
            }

            visitados[actual] = true;

            //RECORRER VECINOS
            for(int vecino = 0; vecino < cantidadEstaciones; vecino++) {

                if(conexiones[actual][vecino].existe) {
                    int nuevoCosto = distancia[actual] + conexiones[actual][vecino].costoEnergia;
                }
                // RELAJACIÓN
                if(nuevoCosto < distancia[vecino]) {
                    distancia[vecino] = nuevoCosto;
                }
            }
        }

        //RESUTADO FINAL 
        if(distancia[destinoId] == COSTO_INFINITO)
        return -1;

        return distancia[destinoId];
    }         
    
};

int main() {
    MetroNocturno metro;
    metro.agregarEstacion("Central"); // ID 0
    metro.agregarEstacion("Neon");    // ID 1
    metro.agregarEstacion("Docks");   // ID 2
    metro.agregarEstacion("Norte");   // ID 3

    metro.conectarBidireccional(0, 1, 7);
    metro.conectarBidireccional(0, 2, 2);
    metro.conectarBidireccional(2, 1, 1);
    metro.conectarBidireccional(1, 3, 4);

    cout << "--- PRUEBA DEL ENUNCIADO ---" << endl;
    int resultado = metro.costoMinimoEnergia(0, 3);
    cout << "Esperado: 7 | Conseguido: " << resultado << endl;

    cout << "\n--- PRUEBAS DE CASOS BORDE ---" << endl;
    cout << "Coinciden origen y destino (Esperado: 0)   | Conseguido: " << metro.costoMinimoEnergia(1, 1) << endl;
    cout << "ID origen inválido (-1)    (Esperado: -1)  | Conseguido: " << metro.costoMinimoEnergia(-1, 3) << endl;
    cout << "ID destino inexistente (5) (Esperado: -1)  | Conseguido: " << metro.costoMinimoEnergia(0, 5) << endl;

    return 0;
};