template <typename TData>
void printQueue(Queue<TData>& q) {
    std::size_t n = q.size();
    for (std::size_t i = 0; i < n; ++i) {
        TData val = q.front();
        std::cout << val;
        if (i + 1 < n) std::cout << " ";
        q.dequeue();
        q.enqueue(val);
    }
    std::cout << "\n";
}
